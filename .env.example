# ── SERVER ──────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── DATABASE (PostgreSQL) ────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gsrtc_epass
DB_USER=postgres
DB_PASSWORD=your_password_here

# Full connection string (alternative to above)
# DATABASE_URL=postgresql://postgres:your_password@localhost:5432/gsrtc_epass

# ── JWT ─────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_key
JWT_REFRESH_EXPIRES_IN=30d

# ── ADMIN CREDENTIALS (first run) ───────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=gsrtc@2025
ADMIN_EMAIL=admin@gsrtc.gujarat.gov.in

# ── FILE UPLOADS ─────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=5

# ── EMAIL (Nodemailer - optional) ───────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=noreply@gsrtc.gujarat.gov.in

# ── CORS ─────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5500,http://127.0.0.1:5500

# ── RATE LIMITING ────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10
